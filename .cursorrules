Пример моего реального рабочего кода с OpenEvolve для эволюции промпта. Он писался под другую задачу, но LLM выбросила все лишнее. В нашей задаче sampling не понадобится
---
!pip install -q openevolve transformers accelerate torch openai matplotlib

import os
import json
import torch
import numpy as np
from openai import OpenAI

DETECTOR_MODEL_ID = "danibor/oculus-v2.0-multilingual"

ESSAY_TOPICS = [
    "El realismo mágico en Cien años de soledad",
]

API_BASE = "https://api.zveno.ai/v1"
API_KEY = "YOUR_TOKEN"
LLM_MODEL = "openai/gpt-oss-120b"

EXPERIMENT_DIR = "./prompt_evolution_ai_detector"
os.makedirs(EXPERIMENT_DIR, exist_ok=True)

config_yaml = f"""
llm:
  models:
    - name: {LLM_MODEL}
      api_base: {API_BASE}
      api_key: "{API_KEY}"
      api_type: openai
      default_params:
        temperature: 1.0
        top_p: 0.95
        max_tokens: 10000

evolution:
  generations: 100
  population_size: 100
  elitism: 20

operators:
  mutation:
    type: llm
    llm_model: {LLM_MODEL}
    prompt_template: |
      You are improving a system prompt that instructs a language model to write Spanish essays.
      The goal is to make the generated essays appear human-written and avoid detection by an AI detector.
      Current prompt:
      """{{program}}"""
      Its evasion score (higher = better) is {{score:.4f}}.
      Propose a modified prompt that increases the evasion score.
      You may change wording, add style instructions, or introduce new constraints.
      Output only the new prompt text, nothing else.
  crossover:
    type: llm
    llm_model: {LLM_MODEL}
    probability: 0.8
    prompt_template: |
      Combine two system prompts to create a superior one for generating human-like Spanish essays.
      Prompt A (score {{score_a:.4f}}): """{{program_a}}"""
      Prompt B (score {{score_b:.4f}}): """{{program_b}}"""
      Output only the new prompt.

selection:
  type: tournament
  tournament_size: 5
"""

config_path = os.path.join(EXPERIMENT_DIR, "config_evolution.yaml")
with open(config_path, "w", encoding="utf-8") as f:
    f.write(config_yaml.strip())

INITIAL_PROMPT = "Eres un estudiante que escribe un ensayo académico en español. Escribe de manera natural, con algunos errores menores y estilo personal."

initial_prompt_path = os.path.join(EXPERIMENT_DIR, "initial_prompt.txt")
with open(initial_prompt_path, "w", encoding="utf-8") as f:
    f.write(INITIAL_PROMPT)

best_path = os.path.join(EXPERIMENT_DIR, "best_program.txt")
with open(best_path, "w", encoding="utf-8") as f:
    f.write(INITIAL_PROMPT)

%%writefile evaluator.py
import sys
import os
import json
import torch
import numpy as np
from openai import OpenAI
from transformers import AutoTokenizer, AutoModel, PreTrainedModel, AutoConfig
import torch.nn as nn

class DetectorModel(PreTrainedModel):
    config_class = AutoConfig
    all_tied_weights_keys = {}

    def __init__(self, config):
        super().__init__(config)
        self.model = AutoModel.from_config(config)
        self.classifier = nn.Linear(config.hidden_size, 1)
        self.init_weights()

    def forward(self, input_ids=None, attention_mask=None, **kwargs):
        outputs = self.model(input_ids=input_ids, attention_mask=attention_mask)
        last_hidden = outputs[0]
        mask_expanded = attention_mask.unsqueeze(-1).expand(last_hidden.size()).float()
        sum_embeddings = torch.sum(last_hidden * mask_expanded, dim=1)
        sum_mask = torch.clamp(mask_expanded.sum(dim=1), min=1e-9)
        pooled = sum_embeddings / sum_mask
        pooled = pooled.to(self.classifier.weight.dtype)
        logits = self.classifier(pooled)
        return {"logits": logits}

DETECTOR_MODEL_ID = "danibor/oculus-v2.0-multilingual"
DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")

tokenizer = AutoTokenizer.from_pretrained(DETECTOR_MODEL_ID)
detector = DetectorModel.from_pretrained(DETECTOR_MODEL_ID).to(DEVICE)
detector.eval()

API_BASE = os.environ.get("OPENAI_API_BASE", "https://api.zveno.ai/v1")
API_KEY = os.environ.get("OPENAI_API_KEY", "YOUR_TOKEN")
client = OpenAI(base_url=API_BASE, api_key=API_KEY)
LLM_MODEL = os.environ.get("LLM_MODEL", "openai/gpt-oss-120b")

ESSAY_TOPICS = json.loads(os.environ.get("ESSAY_TOPICS", '["El realismo mágico en Cien años de soledad", "La figura del héroe trágico en La vida es sueño", "El papel de la mujer en La casa de los espíritus", "El existencialismo en Nada de Carmen Laforet", "La crítica social en Los santos inocentes", "El amor y la muerte en Bodas de sangre", "La soledad en la poesía de Federico García Lorca", "La identidad latinoamericana en la obra de Borges", "El honor en El alcalde de Zalamea", "La libertad en La Regenta"]'))

def evaluate(program: str) -> dict:
    logits = []
    for topic in ESSAY_TOPICS:
        messages = [
            {"role": "system", "content": program},
            {"role": "user", "content": f"Escribe un ensayo sobre: {topic}"}
        ]
        try:
            resp = client.chat.completions.create(
                model=LLM_MODEL,
                messages=messages,
                max_tokens=1024,
                temperature=0.0
            )
            essay = resp.choices[0].message.content.strip()
        except Exception:
            essay = ""

        if not essay:
            continue

        inputs = tokenizer(
            essay,
            return_tensors="pt",
            truncation=True,
            max_length=512,
            padding="max_length"
        ).to(DEVICE)

        with torch.no_grad():
            logit = detector(**inputs)["logits"].item()
        logits.append(logit)

    if not logits:
        return {"combined_score": 0.0}

    avg_logit = np.mean(logits)
    score = -avg_logit
    return {"combined_score": score}

if __name__ == "__main__":
    if len(sys.argv) > 1:
        test_prompt = sys.argv[1]
    else:
        test_prompt = "Eres un estudiante que escribe un ensayo académico en español."
    result = evaluate(test_prompt)
    print(result)

import nest_asyncio
nest_asyncio.apply()

os.environ["OPENAI_API_KEY"] = API_KEY
os.environ["OPENAI_API_BASE"] = API_BASE
os.environ["LLM_MODEL"] = LLM_MODEL
os.environ["ESSAY_TOPICS"] = json.dumps(ESSAY_TOPICS, ensure_ascii=False)

from openevolve.api import run_evolution
from openevolve.config import load_config

config = load_config(config_path)
output_dir = os.path.join(EXPERIMENT_DIR, "openevolve_output")

result = run_evolution(
    initial_program=initial_prompt_path,
    evaluator="evaluator.py",
    config=config,
    iterations=config["evolution"]["generations"],
    output_dir=output_dir,
    cleanup=False,
)

print("Best evasion score:", result.best_score)
if hasattr(result, "best_code") and result.best_code:
    with open(os.path.join(EXPERIMENT_DIR, "best_prompt_evolved.txt"), "w") as f:
        f.write(result.best_code)
    print("Best prompt saved.")
